{
  "name": "edamajutsu",
  "displayName": "edamajutsu",
  "description": "Magit-style interface for Jujutsu (jj) in VSCode",
  "version": "0.0.1",
  "preview": true,
  "publisher": "crouton-ai",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "jj",
    "jujutsu",
    "magit",
    "vcs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bokken12/edamajutsu.git"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "edamajutsu",
        "aliases": [
          "Edamajutsu"
        ],
        "extensions": [
          ".edamajutsu"
        ],
        "configuration": "./languages/edamajutsu.language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "[edamajutsu]": {
        "editor.lineNumbers": "off",
        "editor.minimap.enabled": false,
        "editor.renderWhitespace": "none",
        "editor.wordWrap": "off",
        "editor.glyphMargin": false,
        "editor.folding": true,
        "editor.foldingStrategy": "auto",
        "editor.showFoldingControls": "always"
      }
    },
    "commands": [
      {
        "command": "edamajutsu.openStatus",
        "title": "Edamajutsu: Open Status"
      },
      {
        "command": "edamajutsu.openLog",
        "title": "Edamajutsu: Open Log"
      },
      {
        "command": "edamajutsu.openOpLog",
        "title": "Edamajutsu: Open Op Log"
      },
      {
        "command": "edamajutsu.refresh",
        "title": "Edamajutsu: Refresh"
      },
      {
        "command": "edamajutsu.visitAtPoint",
        "title": "Edamajutsu: Visit at Point"
      },
      {
        "command": "edamajutsu.undo",
        "title": "Edamajutsu: Undo Last Operation"
      },
      {
        "command": "edamajutsu.new",
        "title": "Edamajutsu: New Change"
      },
      {
        "command": "edamajutsu.describe",
        "title": "Edamajutsu: Describe Working Copy"
      },
      {
        "command": "edamajutsu.abandon",
        "title": "Edamajutsu: Abandon Change at Point"
      },
      {
        "command": "edamajutsu.edit",
        "title": "Edamajutsu: Edit Change at Point"
      },
      {
        "command": "edamajutsu.bookmark.create",
        "title": "Edamajutsu: Create Bookmark at Change at Point"
      },
      {
        "command": "edamajutsu.bookmark.set",
        "title": "Edamajutsu: Move Existing Bookmark to Change at Point"
      },
      {
        "command": "edamajutsu.squash",
        "title": "Edamajutsu: Squash Working Copy Into Parent"
      },
      {
        "command": "edamajutsu.redo",
        "title": "Edamajutsu: Redo Last Undone Operation"
      },
      {
        "command": "edamajutsu.duplicate",
        "title": "Edamajutsu: Duplicate Change at Point"
      },
      {
        "command": "edamajutsu.revert",
        "title": "Edamajutsu: Revert Change at Point (apply its reverse)"
      },
      {
        "command": "edamajutsu.bookmark.delete",
        "title": "Edamajutsu: Delete Bookmark"
      },
      {
        "command": "edamajutsu.bookmark.rename",
        "title": "Edamajutsu: Rename Bookmark"
      },
      {
        "command": "edamajutsu.bookmark.forget",
        "title": "Edamajutsu: Forget Bookmark (local only, don't propagate to remotes)"
      },
      {
        "command": "edamajutsu.closeView",
        "title": "Edamajutsu: Close View"
      },
      {
        "command": "edamajutsu.help",
        "title": "Edamajutsu: Help (browse commands)"
      },
      {
        "command": "edamajutsu.rebase",
        "title": "Edamajutsu: Rebase Change at Point + Descendants"
      },
      {
        "command": "edamajutsu.git.push",
        "title": "Edamajutsu: Git Push (jj git push --allow-new)"
      },
      {
        "command": "edamajutsu.git.pushBookmark",
        "title": "Edamajutsu: Git Push Specific Bookmark (jj git push --bookmark <name>)"
      },
      {
        "command": "edamajutsu.git.fetch",
        "title": "Edamajutsu: Git Fetch (jj git fetch)"
      },
      {
        "command": "edamajutsu.absorb",
        "title": "Edamajutsu: Absorb Working Copy Into Ancestors"
      },
      {
        "command": "edamajutsu.bookmark.menu",
        "title": "Edamajutsu: Bookmark Menu"
      },
      {
        "command": "edamajutsu.git.menu",
        "title": "Edamajutsu: Git Menu"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "edamajutsu.refresh",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.visitAtPoint",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.undo",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.new",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.describe",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.abandon",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.edit",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.bookmark.create",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.bookmark.set",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.squash",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.redo",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.duplicate",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.revert",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.bookmark.delete",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.bookmark.rename",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.bookmark.forget",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.closeView",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.help",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.rebase",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.git.push",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.git.pushBookmark",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.git.fetch",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.absorb",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.bookmark.menu",
          "when": "editorLangId == edamajutsu"
        },
        {
          "command": "edamajutsu.git.menu",
          "when": "editorLangId == edamajutsu"
        }
      ]
    },
    "keybindings": [
      {
        "command": "edamajutsu.refresh",
        "key": "g",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.openLog",
        "key": "l",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.openOpLog",
        "key": "o",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.visitAtPoint",
        "key": "enter",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.undo",
        "key": "u",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.new",
        "key": "n",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.describe",
        "key": "c",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.abandon",
        "key": "k",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.edit",
        "key": "e",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.bookmark.menu",
        "key": "b",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.squash",
        "key": "s",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.redo",
        "key": "shift+u",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.duplicate",
        "key": "y",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.revert",
        "key": "shift+v",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.closeView",
        "key": "q",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.help",
        "key": "shift+/",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.rebase",
        "key": "r",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.git.menu",
        "key": "shift+g",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      },
      {
        "command": "edamajutsu.absorb",
        "key": "a",
        "when": "editorTextFocus && editorLangId == edamajutsu"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "webpack --mode production",
    "build": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "compile": "tsc -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run -u",
    "demo:log": "tsc -p ./ && node ./out/demo/log.js",
    "demo:log:graph": "tsc -p ./ && node ./out/demo/logGraph.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.7",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
